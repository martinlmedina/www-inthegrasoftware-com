AddDefaultCharset UTF-8
RewriteEngine On

# ─── WebP auto-serve: si el browser acepta webp y existe foo.png.webp, servirlo ───
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_ACCEPT} image/webp
  RewriteCond %{REQUEST_FILENAME} \.(png|jpe?g)$
  RewriteCond %{REQUEST_FILENAME}.webp -f
  RewriteRule ^ %{REQUEST_URI}.webp [T=image/webp,E=accept:1,L]
</IfModule>

# ─── 301: URLs legacy específicas de Inthegra → archivos .html canónicos ───
RewriteRule ^erp-creditos/?$ /landing_credit_financial.html [R=301,L]
RewriteRule ^salud-erp/?$ /landing_healthcare.html [R=301,L]
RewriteRule ^nosotros/?$ /people_culture.html [R=301,L]
RewriteRule ^people-culture/?$ /people_culture.html [R=301,L]
RewriteRule ^crm/?$ /solutions_crm.html [R=301,L]
RewriteRule ^casos-de-valor(/.*)?$ /success_stories.html? [R=301,L]

# 410 Gone: /en/ root (basura WP viejo; subrutas /en/* libres para futura i18n)
RewriteRule ^en/?$ - [G,L]

# ─── 410 Gone: URLs legacy genéricas de WordPress (sitio anterior) ───
RewriteRule ^category(/.*)?$ - [G,L]
RewriteRule ^tag(/.*)?$ - [G,L]
RewriteRule ^author(/.*)?$ - [G,L]
RewriteRule ^feed/?$ - [G,L]
RewriteRule ^comments/feed/?$ - [G,L]
RewriteRule ^wp-(content|admin|includes|json|login\.php).* - [G,L]
RewriteRule ^xmlrpc\.php$ - [G,L]
RewriteRule ^wp-sitemap.*\.xml$ - [G,L]

# ?p=N y ?page_id=N (permalinks viejos de WP basados en query string)
RewriteCond %{QUERY_STRING} ^p=[0-9]+(&.*)?$ [OR]
RewriteCond %{QUERY_STRING} ^page_id=[0-9]+(&.*)?$
RewriteRule ^$ - [G,L]

# ─── Root ───
RewriteRule ^$ /index.html [L]

# ─── 301: URLs limpias → archivos .html ───
# Compatibilidad con bookmarks/links externos que usen las URLs limpias.
# El canónico es ahora el archivo .html directo.
RewriteRule ^productos/?$ /index_productos.html [R=301,L]
RewriteRule ^productos/healthcare/?$ /landing_healthcare.html [R=301,L]
RewriteRule ^productos/credit-financial/?$ /landing_credit_financial.html [R=301,L]
RewriteRule ^productos/retail/?$ /landing_erp.html [R=301,L]
RewriteRule ^productos/retail/ecommerce/?$ /landing_erp_ecommerce.html [R=301,L]
RewriteRule ^productos/retail/people-care/?$ /landing_erp_people_care.html [R=301,L]
RewriteRule ^productos/retail/supply-chain/?$ /landing_erp_supply_chain.html [R=301,L]
RewriteRule ^productos/retail/wms/?$ /landing_erp_wms.html [R=301,L]

RewriteRule ^servicios-oracle/?$ /index_services.html [R=301,L]
RewriteRule ^servicios-oracle/modernizacion/?$ /landing_modernizacion.html [R=301,L]
RewriteRule ^servicios-oracle/oci/?$ /landing_oci.html [R=301,L]
RewriteRule ^servicios-oracle/desarrollo-medida/?$ /landing_desarrollo_medida.html [R=301,L]
RewriteRule ^servicios-oracle/analytics/?$ /landing_oac.html [R=301,L]
RewriteRule ^servicios-oracle/production-ai/?$ /landing_production_ai.html [R=301,L]

RewriteRule ^soluciones/crm/?$ /solutions_crm.html [R=301,L]
RewriteRule ^soluciones/ai-chatbot/?$ /solutions_ai_chatbot.html [R=301,L]
RewriteRule ^soluciones/automatizaciones/?$ /solutions_automations.html [R=301,L]

RewriteRule ^equipo/?$ /people_culture.html [R=301,L]
RewriteRule ^casos-de-exito/?$ /success_stories.html [R=301,L]
RewriteRule ^contacto/?$ /contacto.html [R=301,L]
RewriteRule ^privacidad/?$ /privacidad.html [R=301,L]
RewriteRule ^terminos/?$ /terminos.html [R=301,L]

RewriteRule ^blog/?$ /blog.html [R=301,L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^blog/(.+)$ /blog/$1 [L]

RewriteRule ^docs/ - [F,L]
RewriteRule ^(mock_|mockup-|home_oldversion|view-source_) - [F,L]

ErrorDocument 404 /404.html

# ─── Compresión Brotli (preferido) + Gzip (fallback) ───
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml application/xml
</IfModule>
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml application/xml
</IfModule>

# ─── Cache: 1 año para estáticos, 0 para HTML ───
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                 "access plus 0 seconds"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType text/javascript           "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/avif                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/x-icon             "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|svg|webp|avif|png|jpe?g|ico|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  Header append Vary Accept env=accept
</IfModule>
